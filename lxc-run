#!/bin/bash -eu

# Colors
__CEE="\033[91m"
__CII="\033[96m"
__CNO="\033[0m"

# Print helpers
function prerror() { echo -e "${__CEE}EE: $*${__CNO}" >&2 ; }
function prinfo()  { echo -e "${__CII}II: $*${__CNO}" ; }

function lxc_image_exists()
{
	local image=${1}

	lxc image info "${image}" &>/dev/null
}

function lxc_remote_image()
{
	local series=${1} arch=${2}

	if ubuntu-distro-info --all | grep -q "${series}" ; then
		echo "ubuntu-daily:${series}/${arch}"
		return
	fi

	if debian-distro-info --all | grep -q "${series}" ; then
		echo "images:debian/${series}"
		return
	fi

	prerror "Unsupported image series: ${series}"
	return 1
}

function lxc_image_copy()
{
	local image=${1} series=${2} arch=${3}
	local remote_image

	remote_image=$(lxc_remote_image "${series}" "${arch}")

	prinfo "Copy image: ${remote_image} -> ${image}"
	lxc image copy "${remote_image}" local: --alias "${image}"
}

function lxc_exists()
{
	lxc info "${1}" &>/dev/null
}

function lxc_status()
{
	{
		lxc info "${1}" 2>/dev/null || echo "Status: NOTFOUND"
	} | sed -n 's/^Status: *//p'
}

function lxc_wait()
{
	local name=${1}

	prinfo "Wait for container"
	while true ; do
		case "$(lxc exec "${name}" -- systemctl is-system-running || true)" in
			running|degraded)
				return
				;;
		esac
		sleep 1
	done
}

function lxc_user_id()
{
	local name=${1} user=${2}

	lxc exec "${name}" -- id -u "${user}" 2>/dev/null || true
}

function lxc_group_id()
{
	local name=${1} group=${2}

	lxc exec "${name}" -- getent group "${group}" | awk -F: '{print $3 }'
}

function lxc_launch()
{
	local name=${1} series=${2} arch=${3}
	local image lxc_gid lxc_uid

	image=${series}-${arch}
	if ! lxc_image_exists "${image}" ; then
		lxc_image_copy "${image}" "${series}" "${arch}"
	fi

	prinfo "Launch container: ${name}"

	lxc launch local:"${image}" "${name}"
	lxc_wait "${name}"

	prinfo "Configure container"

	# Add group
	lxc_gid=$(lxc_group_id "${name}" "${GROUP}")
	if [ -z "${lxc_gid}" ] ; then
		prinfo "Add group ${GROUP}"
		lxc exec "${name}" -- groupadd "${GROUP}"
		lxc_gid=$(lxc_group_id "${name}" "${GROUP}")
	fi

	# Add user
	lxc_uid=$(lxc_user_id "${name}" "${USER}")
	if [ -z "${lxc_uid}" ] ; then
		prinfo "Add user ${USER}"
		lxc exec "${name}" -- useradd --gid "${lxc_gid}" --home-dir /home/"${USER}" \
		    --no-create-home --shell /bin/bash "${USER}"
		lxc_uid=$(lxc_user_id "${name}" "${USER}")
	fi

	# Create custom profile.d
	prinfo "Create /etc/profile.d/lxc_custom.sh"
	lxc exec "${name}" -- bash -c 'cat > /etc/profile.d/lxc_custom.sh' << EOF
eval "$(dircolors -b)"

alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

alias rm="rm -i"
alias mv="mv -i"
alias cp="cp -i"

PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
EOF

	# Enable sudo
	prinfo "Enable sudo for user ${USER}"
	cat <<EOF | lxc exec "${name}" -- bash -
echo "${USER} ALL = NOPASSWD: ALL" > /etc/sudoers.d/"${USER}"
chmod 440 /etc/sudoers.d/"${USER}"
EOF

	# Create the home directory
	if [ ${ATTACH_HOME} -eq 0 ] && ! lxc exec "${name}" -- test -d /home/"${USER}" ; then
		prinfo "Create home directory /home/${USER}"
		cat <<EOF | lxc exec "${name}" -- bash -
mkdir -p /home/${USER}
cp -r /etc/skel/. /home/${USER}/
chown -R ${lxc_uid}:${lxc_gid} /home/${USER}
chmod 755 /home/${USER}
EOF
	fi

	# Stop the container (required for ID mapping to take effect)
	prinfo "Stop container"
	lxc stop "${name}"

	# Map group and user IDs
	cat <<EOF | lxc config set "${name}" raw.idmap -
gid $(id -g) ${lxc_gid}
uid $(id -u) ${lxc_uid}
EOF

	# Attach our home directory
	if [ ${ATTACH_HOME} -eq 1 ] ; then
		prinfo "Attach home directory /home/${USER} to container"
		lxc config device add "${name}" home disk source="${HOME}" path=/home/"${USER}"
	fi

	# Attach the data directory
	if [ ${ATTACH_DATA} -eq 1 ] ; then
		prinfo "Attach data directory /data to container"
		lxc config device add "${name}" data disk source=/data path=/data
	fi

	# Store the group and user IDs in the config
	lxc config set "${name}" user.gid."${GROUP}" "${lxc_gid}"
	lxc config set "${name}" user.uid."${USER}" "${lxc_uid}"

	# Start the container again
	prinfo "Start container"
	lxc start "${name}"
	lxc_wait "${name}"
}

function lxc_start()
{
	local name=${1}

	prinfo "Start container"
	lxc start "${name}"
	lxc_wait "${name}"
}

function usage()
{
	cat <<EOF
Usage: lxc-run [-h] [--root] [--series SERIES] [-v] [--vm] [NAME] [-- COMMAND [ARG]...]

Run the given command in an LXC container. Create the container first if it
doesn't exits.

Postional arguments:
  NAME              LXC container name (default: ${series}-${arch}).
  COMMAND [ARG]...  Command to run (default: /usr/bin/bash).

Optional argument:
  -h, --help        Show this help text and exit.
  --no-data         Don't attach the data directory to the container.
  --no-home         Don't attach the home directory to the container.
  --root            Run command as the root user.
  --series SERIES   OS series name (default: ${series}).
  -v, --verbose     Enable verbose output.
EOF
}

GROUP=$(id -gn)

ATTACH_DATA=1
ATTACH_HOME=1

arch=$(dpkg-architecture -qDEB_HOST_ARCH)
root=0
series=$(lsb_release -s -c)
verbose=0

name=
command=("/usr/bin/bash")

while [ $# -gt 0 ] ; do
	case "${1}" in
		-h|--help)
			usage
			exit
			;;
		--no-data)
			ATTACH_DATA=0
			;;
		--no-home)
			ATTACH_HOME=0
			;;
		--root)
			root=1
			;;
		--series)
			shift
			series=${1}
			;;
		-v|--verbose)
			verbose=1
			;;
		--)
			shift
			command=("${@}")
			break
			;;
		-*)
			prerror "Invalid argument: ${1}"
			exit 2
			;;
		*)
			if [ -n "${name}" ] ; then
				prerror "Invalid argument: ${1}"
				exit 2
			fi
			name=${1}
			;;
	esac
	shift
done

case "${series}" in
	unstable) series=sid ;;
esac

if [ -z "${name}" ] ; then
	name=${series}-${arch}
fi

status=$(lxc_status "${name}")
case "${status}" in
	NOTFOUND)
		echo "Container not found: ${name} (series=${series}, arch=${arch})"
		echo -n "Do you want to create it (y|n)? "
		read -r tmp
		if [ "${tmp,,}" != "y" ] ; then
			exit 0
		fi
		lxc_launch "${name}" "${series}" "${arch}"
		;;
	STOPPED)
		lxc_start "${name}"
		;;
	RUNNING)
		;;
	*)
		prerror "Unexpected container status: ${status}"
		exit 1
		;;
esac

lxc_opts=(
	--cwd "$(pwd)"
	--env debian_chroot="lxc:${name}"
	--mode interactive
)

if [ ${root} -eq 0 ] ; then
	lxc_opts+=(
		--env HOME="${HOME}"
		--env USER="${USER}"
		--group "$(lxc config get "${name}" user.gid."${GROUP}")"
		--user "$(lxc config get "${name}" user.uid."${USER}")"
	)
fi

if [ ${verbose} -eq 1 ] ; then
	set -x
fi

lxc exec "${name}" "${lxc_opts[@]}" -- "${command[@]}"
